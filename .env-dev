# Настройки Telegram бота
BOT_TOKEN=                 # Токен вашего Telegram бота от @BotFather
BACKEND_URL=              # Базовый URL вашего бэкенд-сервера

# Настройки Django
DEBUG=True                # Режим отладки (True для разработки, False для продакшена)
SECRET_KEY=               # Секретный ключ Django (обязательно измените на уникальный)
ALLOWED_HOSTS=            # Список разрешенных хостов через запятую (например, 'localhost,127.0.0.1')
FERNET_KEY=               # Ключ шифрования для Fernet (используется для шифрования чувствительных данных)

# Настройки PostgreSQL
POSTGRES_DB=postgres      # Имя базы данных
POSTGRES_USER=            # Имя пользователя базы данных
POSTGRES_PASSWORD=        # Пароль пользователя базы данных
POSTGRES_HOST=postgres    # Хост базы данных (имя сервиса в Docker)
POSTGRES_PORT=5432        # Порт базы данных

# Настройки Redis
REDIS_HOST=redis          # Хост Redis (имя сервиса в Docker)
REDIS_PORT=6379           # Порт Redis
REDIS_USER=               # Имя пользователя Redis (если требуется аутентификация)
REDIS_PASSWORD=           # Пароль Redis (если требуется аутентификация)